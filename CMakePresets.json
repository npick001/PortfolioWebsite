{
  "version": 3,
  "configurePresets": [
    {
      "name": "x64-debug-vcpkg",
      "displayName": "x64 Debug (vcpkg)",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_TOOLCHAIN_FILE": "Z:/Repos/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_VS_WIN32_APP_LOCAL_DEPLOYMENT": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}